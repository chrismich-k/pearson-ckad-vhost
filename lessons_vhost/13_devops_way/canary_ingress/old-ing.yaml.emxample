apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  creationTimestamp: null
  name: old-version
  annotations:
    cert-manager.io/cluster-issuer: letsencrypt-prod
spec:
  rules:
  - host: theapp.MY_DOMAIN.TLD
    http:
      paths:
      - backend:
          service:
            name: old-nginx
            port:
              number: 80
        path: /
        pathType: Exact
  ingressClassName: nginx
  tls:
  - hosts:
    - theapp.MY_DOMAIN.TLD
    secretName: theapp-tlsstatus
